{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/decentralized-forge/project-registry.schema.json",
  "title": "Decentralized Forge Project Registry",
  "description": "Minimal project registry object for a local decentralized forge MVP.",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "maintainers",
    "clone_urls",
    "created_at",
    "updated_at",
    "substrates",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "decentralized-forge.project-registry.v1"
    },
    "project": {
      "type": "object",
      "required": [
        "id",
        "name",
        "description",
        "default_branch"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "default_branch": {
          "type": "string",
          "minLength": 1
        },
        "web_urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "id_type",
          "public_id"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "id_type": {
            "enum": [
              "nostr",
              "radicle",
              "did",
              "ssh",
              "other"
            ]
          },
          "public_id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string"
          }
        }
      }
    },
    "clone_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "transport",
          "url"
        ],
        "additionalProperties": false,
        "properties": {
          "transport": {
            "enum": [
              "git",
              "https",
              "ssh",
              "radicle",
              "nostr",
              "other"
            ]
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "primary": {
            "type": "boolean"
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "enum": [
              "open",
              "closed"
            ]
          },
          "author": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "enum": [
              "proposed",
              "review",
              "accepted",
              "rejected",
              "merged"
            ]
          },
          "author": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "version",
          "tag",
          "artifacts"
        ],
        "additionalProperties": false,
        "properties": {
          "version": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "sha256",
                "hashes",
                "availability"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "media_type": {
                  "type": "string"
                },
                "size_bytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "uri": {
                  "type": "string"
                },
                "cid": {
                  "type": "string"
                },
                "hashes": {
                  "type": "object",
                  "required": [
                    "sha256"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    }
                  }
                },
                "content_addresses": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "protocol",
                      "cid",
                      "cid_version",
                      "multibase",
                      "multicodec",
                      "multihash",
                      "verification_status"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "protocol": {
                        "enum": [
                          "ipfs"
                        ]
                      },
                      "cid": {
                        "type": "string"
                      },
                      "cid_version": {
                        "const": 1
                      },
                      "multibase": {
                        "const": "base32"
                      },
                      "multicodec": {
                        "type": "string"
                      },
                      "multihash": {
                        "type": "string"
                      },
                      "derived_from_local_fixture": {
                        "type": "boolean"
                      },
                      "matches_artifact_hash": {
                        "type": "boolean"
                      },
                      "verification_status": {
                        "enum": [
                          "local-computed-not-fetched",
                          "synthetic-fixture-not-verified",
                          "live-verified"
                        ]
                      },
                      "notes": {
                        "type": "string"
                      }
                    }
                  }
                },
                "availability": {
                  "type": "object",
                  "required": [
                    "local_fixture",
                    "pinned",
                    "live_ipfs_verified",
                    "paid_storage",
                    "durability_claim"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "local_fixture": {
                      "type": "boolean"
                    },
                    "pinned": {
                      "type": "boolean"
                    },
                    "live_ipfs_verified": {
                      "type": "boolean"
                    },
                    "paid_storage": {
                      "type": "boolean"
                    },
                    "durability_claim": {
                      "type": "boolean"
                    },
                    "notes": {
                      "type": "string"
                    }
                  }
                },
                "signature": {
                  "type": "string"
                },
                "attestation": {
                  "type": "string"
                },
                "provenance": {
                  "type": "object",
                  "required": [
                    "status",
                    "predicate_type",
                    "builder",
                    "repository",
                    "commit",
                    "artifact_name",
                    "artifact_sha256",
                    "ci_check_ids",
                    "synthetic",
                    "verification"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "status": {
                      "enum": [
                        "synthetic-local-only",
                        "absent",
                        "verified"
                      ]
                    },
                    "predicate_type": {
                      "type": "string"
                    },
                    "builder": {
                      "type": "string"
                    },
                    "repository": {
                      "type": "string"
                    },
                    "commit": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{40}$"
                    },
                    "tag": {
                      "type": "string"
                    },
                    "artifact_name": {
                      "type": "string"
                    },
                    "artifact_sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "materials": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "uri",
                          "digest"
                        ],
                        "additionalProperties": false,
                        "properties": {
                          "uri": {
                            "type": "string"
                          },
                          "digest": {
                            "type": "object",
                            "additionalProperties": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    },
                    "ci_check_ids": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "synthetic": {
                      "type": "boolean"
                    },
                    "verification": {
                      "type": "object",
                      "required": [
                        "local_schema_only",
                        "real_sigstore_verified",
                        "real_in_toto_verified",
                        "slsa_level_claimed",
                        "uses_real_signature",
                        "uses_private_key",
                        "notes"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "local_schema_only": {
                          "type": "boolean"
                        },
                        "real_sigstore_verified": {
                          "type": "boolean"
                        },
                        "real_in_toto_verified": {
                          "type": "boolean"
                        },
                        "slsa_level_claimed": {
                          "type": "boolean"
                        },
                        "uses_real_signature": {
                          "type": "boolean"
                        },
                        "uses_private_key": {
                          "type": "boolean"
                        },
                        "notes": {
                          "type": "string"
                        }
                      }
                    },
                    "boundaries": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "substrates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nip34": {
          "type": "object"
        },
        "radicle": {
          "type": "object"
        },
        "forgefed": {
          "type": "object"
        },
        "ipfs": {
          "type": "object"
        },
        "sigstore_slsa": {
          "type": "object"
        }
      }
    },
    "signature": {
      "type": "object",
      "required": [
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "unsigned-fixture",
            "signed"
          ]
        },
        "algorithm": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "ci_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "provider",
          "repository",
          "commit",
          "status",
          "conclusion",
          "synthetic",
          "published",
          "started_at",
          "completed_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "enum": [
              "local-fake",
              "github-actions",
              "gitlab-ci",
              "buildkite",
              "other"
            ]
          },
          "workflow": {
            "type": "string"
          },
          "repository": {
            "type": "string",
            "minLength": 1
          },
          "commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "status": {
            "enum": [
              "queued",
              "in_progress",
              "completed",
              "cancelled",
              "skipped"
            ]
          },
          "conclusion": {
            "enum": [
              "success",
              "failure",
              "neutral",
              "cancelled",
              "skipped",
              "timed_out",
              "action_required"
            ]
          },
          "synthetic": {
            "type": "boolean"
          },
          "published": {
            "type": "boolean"
          },
          "started_at": {
            "type": "string"
          },
          "completed_at": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
