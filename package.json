{
  "name": "decentralized-forge",
  "version": "1.0.0",
  "description": "A research and prototype project for a GitHub-class decentralized forge.",
  "type": "module",
  "private": true,
  "scripts": {
    "verify:local": "python scripts/forge_registry.py verify-local",
    "verify:car-cid": "node scripts/verify_car_cid_fixture.mjs",
    "verify:helia": "node scripts/verify_helia_fixture.mjs",
    "live:gateway-preflight": "node scripts/run_public_gateway_pinning_preflight.mjs",
    "live:nostr-issue-patch": "node scripts/run_nostr_issue_patch_readback.mjs",
    "live:radicle-check": "node scripts/run_radicle_broader_check.mjs",
    "import:keyless-attestation": "python scripts/import_keyless_attestation_registry.py",
    "verify:evidence-index": "python scripts/forge_registry.py validate-evidence-index fixtures/live-evidence-index.json",
    "refresh:evidence-hashes": "python scripts/forge_registry.py refresh-evidence-hashes fixtures/live-evidence-index.json",
    "forge:doctor": "python scripts/forge_registry.py doctor",
    "next:loop": "python scripts/next_loop_controller.py --write-report",
    "next:check": "python scripts/next_loop_controller.py --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redclawanon-rgb/decentralized-forge.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@helia/unixfs": "7.2.1",
    "@ipld/car": "5.4.6",
    "helia": "6.1.4",
    "multiformats": "14.0.0",
    "nostr-tools": "2.23.8"
  }
}
